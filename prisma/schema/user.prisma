model User{
    id String @id @default(uuid())
    name String @db.VarChar(255)
    email String @unique
    password String
    activestatus ActiveStatus @default(ACTIVE)
    role Role @default(USER)
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
    profileId Profile?

    @@map("users")
}

enum ActiveStatus {
    ACTIVE 
    BLOCKED
}

enum Role {
    USER
    AUTHOR
    ADMIN
}